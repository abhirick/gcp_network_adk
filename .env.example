# Use one of these, depending on how you run ADK/Gemini.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=abhishek
GOOGLE_CLOUD_LOCATION=global

# ADK / model settings
ADK_MODEL=gemini-2.5-pro

# Runtime settings
DEFAULT_INSIGHT_LOCATION=global
DEFAULT_MAX_INSIGHTS_PER_TYPE=100
HTTP_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
